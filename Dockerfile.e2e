FROM oven/bun:slim

RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates curl jq \
  && rm -rf /var/lib/apt/lists/*

# Create a non-root user with bash shell
RUN useradd -m -s /bin/bash cursor-user

USER cursor-user
WORKDIR /home/cursor-user

# Shell config must exist for alias step
RUN touch .bashrc

# Copy lockfile first for dependency caching
COPY --chown=cursor-user:cursor-user package.json bun.lock app/
WORKDIR /home/cursor-user/app
RUN bun install --frozen-lockfile

# Copy rest of project files
COPY --chown=cursor-user:cursor-user . .

ENV SHELL=/bin/bash

CMD ["bash", "e2e/run-e2e.sh"]
