{
	"name": "cursor-installer",
	"description": "Utility script to install or update Cursor on Linux",
	"keywords": [
		"cursor",
		"installer",
		"update",
		"install",
		"linux"
	],
	"version": "1.0.0",
	"author": "meteoricprovider",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/meteoricprovider/cursor-installer.git"
	},
	"private": false,
	"type": "module",
	"main": "src/index.ts",
	"engines": {
		"bun": "^1.2.21"
	},
	"bin": {
		"cursor-installer": "src/main.ts"
	},
	"scripts": {
		"prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
		"format": "biome format --write ./src",
		"lint": "biome lint ./src",
		"lint:check": "biome check ./src",
		"dev": "bun run ./src/main.ts",
		"test": "bun test",
		"test:e2e": "docker build -f Dockerfile.e2e -t cursor-installer-e2e . && docker run --rm cursor-installer-e2e",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@clack/core": "1.1.0",
		"@clack/prompts": "1.1.0",
		"@effect/cluster": "0.58.0",
		"@effect/platform": "0.96.0",
		"@effect/platform-bun": "0.89.0",
		"@effect/rpc": "0.75.0",
		"@effect/sql": "0.51.0",
		"effect": "3.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "1.3.11",
		"@typescript/native-preview": "7.0.0-dev.20260327.2"
	},
	"peerDependencies": {
		"typescript": "6.0.2"
	}
}
